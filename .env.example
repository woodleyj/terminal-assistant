# TASS Environment Variables
# Copy this file to .env and fill in your details

# REQUIRED: Your Gemini API Key from https://aistudio.google.com/app/apikey
GEMINI_TASS_API_KEY=your_api_key_here

# OPTIONAL: Custom aliases (comma-separated, e.g., ask,ai)
TASS_USER_ALIASES=

# OPTIONAL: Max number of interactions to remember (1-20)
TASS_MEMORY_LIMIT=5

# OPTIONAL: Override the default system prompt
# TASS_SYSTEM_PROMPT_OVERRIDE=
